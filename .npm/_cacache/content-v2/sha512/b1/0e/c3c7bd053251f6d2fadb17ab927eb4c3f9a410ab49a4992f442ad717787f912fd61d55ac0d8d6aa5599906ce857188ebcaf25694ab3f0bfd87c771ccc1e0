/*.js","browsers":{"iexplore":["6.0","7.0","8.0","9.0"],"chrome":["15.0","20.0"],"firefox":["10.0","15.0"],"safari":["5.1"],"opera":["12.0"]}},"repository":{"type":"git","url":"http://github.com/substack/gamma.js.git"},"keywords":["Γ","gamma","factorial","mathematics","lanczos","approximation"],"author":{"name":"James Halliday","email":"mail@substack.net","url":"http://substack.net"},"license":"MIT","gitHead":"4b20b4a6d3840f1144f8ffae1eb52867a7f1e3df","bugs":{"url":"https://github.com/substack/gamma.js/issues"},"homepage":"https://github.com/substack/gamma.js","_id":"gamma@1.0.0","_shasum":"983c1c939fe23d932701585711e1d9a430cb74cb","_from":".","_npmVersion":"2.0.0","_npmUser":{"name":"substack","email":"mail@substack.net"},"maintainers":[{"name":"substack","email":"mail@substack.net"}],"dist":{"shasum":"983c1c939fe23d932701585711e1d9a430cb74cb","tarball":"https://registry.npmjs.org/gamma/-/gamma-1.0.0.tgz","integrity":"sha512-bPI4QJKNe/PfuO6PZU7ckMkBk0wEe3iQWx3DadEp5ceiAkJwc8CRukwncOZ5Hk5rc6nNTbIfByZKGz7Vv+xXdw==","signatures":[{"keyid":"SHA256:jl3bwswu80PjjokCgh0o2w5c2U4LhQAE57gj9cz1kzA","sig":"MEUCIQCig6edBPIlbLzqJI65+qztYq81vNzxB74HYrk+1wL1nwIgWpWHIg0hzQANvdK9RDNFurLK9TlnTMmE6p1ehqAKcfc="}]},"directories":{}}},"readme":"# gamma\n\n[gamma function](http://en.wikipedia.org/wiki/Gamma_function)\nin javascript using the\n[lanczos approximation](http://en.wikipedia.org/wiki/Lanczos_approximation)\nfor small values and the \n[spouge approximation](https://en.wikipedia.org/wiki/Spouge's_approximation) for\nlarger values\n\n[![browser support](http://ci.testling.com/substack/gamma.js.png)](http://ci.testling.com/substack/gamma.js)\n\n[![build status](https://secure.travis-ci.org/substack/gamma.js.png)](http://travis-ci.org/substack/gamma.js)\n\n# example\n\n```\n> var gamma = require('gamma')\n> gamma(5)\n23.999999999999996\n> gamma(1.6)\n0.8935153492876909\n```\n\n# methods\n\nvar gamma = require('gamma')\n\n## gamma(z)\n\nReturn the gamma function over `z`. Complex numbers aren't supported, only reals.\n\n## gamma.log(z)\n\nReturn the natural log of the gamma function for `z`.\n\nThis function is used internally by the spouge approximation to compute large\nvalues.\n\n# install\n\nWith [npm](http://npmjs.org) do:\n\n```\nnpm install gamma\n```\n\n# kudos\n\nImplementation transliterated from the python script on the wikipedia entry for\nthe\n[lanczos approximation](http://en.wikipedia.org/wiki/Lanczos_approximation).\n\nSpouge approximation from [Niggler](https://github.com/Niggler).\n\n# license\n\nMIT\n","maintainers":[{"email":"nopersonsmodules@gmail.com","name":"nopersonsmodules"}],"time":{"modified":"2022-11-11T06:35:04.454Z","created":"2012-02-14T07:25:37.873Z","0.0.0":"2012-02-14T07:25:44.760Z","0.0.1":"2012-12-17T05:22:40.201Z","0.1.0":"2013-03-19T23:16:56.470Z","1.0.0":"2014-09-25T10:06:10.039Z"},"author":{"name":"James Halliday","email":"mail@substack.net","url":"http://substack.net"},"repository":{"type":"git","url":"http://github.com/substack/gamma.js.git"},"homepage":"https://github.com/substack/gamma.js","keywords":["Γ","gamma","factorial","mathematics","lanczos","approximation"],"bugs":{"url":"https://github.com/substack/gamma.js/issues"},"license":"MIT","readmeFilename":"readme.markdown","users":{"chrisco":true}}